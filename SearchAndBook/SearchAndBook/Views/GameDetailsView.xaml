<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SearchAndBook.Views.GameDetailsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SearchAndBook.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="30,80,30,30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR: Back button + Title -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="← Back"
                    Click="OnBackClicked"
                    VerticalAlignment="Center"
                    Margin="0,0,16,0"/>

            <TextBlock Grid.Column="1"
                       Text="{Binding gameAndUserDetails.name}"
                       FontSize="28"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- ERROR BANNER -->
        <InfoBar Grid.Row="1"
                 Title="Error"
                 Message="Could not retrieve listing details. Please try again later."
                 Severity="Error"
                 IsOpen="{Binding hasError}"
                 Margin="0,0,0,12"/>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== LEFT SIDE ===== -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="20">

                    <!-- IMAGE + INFO SIDE BY SIDE -->
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="20">

                        <Border Grid.Column="0"
                                Width="220"
                                Height="180"
                                CornerRadius="10">
                            <Border.Background>
                                <ImageBrush ImageSource="{Binding gameAndUserDetails.image}"
                                            Stretch="UniformToFill"/>
                            </Border.Background>
                        </Border>

                        <StackPanel Grid.Column="1" Spacing="10" VerticalAlignment="Center">

                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="📍" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding gameAndUserDetails.city}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="👥" VerticalAlignment="Center"/>
                                <TextBlock VerticalAlignment="Center">
                                    <Run Text="{Binding gameAndUserDetails.minimumNrPlayers}"/>
                                    <Run Text=" – "/>
                                    <Run Text="{Binding gameAndUserDetails.maximumNrPlayers}"/>
                                    <Run Text=" players"/>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="💰" VerticalAlignment="Center"/>
                                <TextBlock VerticalAlignment="Center">
                                    <Run Text="{Binding gameAndUserDetails.price}"/>
                                    <Run Text=" $/day"/>
                                </TextBlock>
                            </StackPanel>

                        </StackPanel>
                    </Grid>

                    <!-- DIVIDER -->
                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                    <!-- DESCRIPTION -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="Description"
                                   FontSize="18"
                                   FontWeight="Bold"/>
                        <TextBlock Text="{Binding gameAndUserDetails.description}"
                                   TextWrapping="Wrap"
                                   MinHeight="52"
                                   LineHeight="22"/>
                    </StackPanel>

                    <!-- DIVIDER -->
                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                    <!-- USER'S PROFILE -->
                    <StackPanel Spacing="10">

                        <TextBlock Text="User's profile"
                                   FontSize="16"
                                   FontWeight="Bold"/>

                        <Ellipse Width="60" Height="60" Fill="#AAA"
                                 HorizontalAlignment="Left"/>

                        <TextBlock Text="{Binding gameAndUserDetails.displayName}"
                                   FontWeight="SemiBold"/>

                        <TextBlock FontSize="12">
                            <Run Text="Since "/>
                            <Run Text="{Binding gameAndUserDetails.createdAt}"/>
                        </TextBlock>

                        <Button Content="Chat with user"/>

                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <!-- ===== RIGHT SIDE (Booking Panel) ===== -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="16">

                    <Border CornerRadius="12"
                            Padding="20"
                            BorderThickness="1"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                        <StackPanel Spacing="16">

                            <TextBlock Text="Book this game"
                                       FontSize="20"
                                       FontWeight="Bold"/>

                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock FontSize="22" FontWeight="Bold">
                                    <Run Text="{Binding gameAndUserDetails.price}"/>
                                    <Run Text="$"/>
                                </TextBlock>
                                <TextBlock Text="/ day"
                                           VerticalAlignment="Bottom"
                                           Margin="0,0,0,3"/>
                            </StackPanel>

                            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                            <TextBlock Text="Choose dates" FontWeight="SemiBold"/>

                            <CalendarView x:Name="RentalCalendar"
                                          SelectionMode="Multiple"
                                          HorizontalAlignment="Stretch"
                                          SelectedDatesChanged="OnDatesChanged"/>

                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Ellipse Width="12" Height="12" Fill="Red" VerticalAlignment="Center"/>
                                    <TextBlock Text="Unavailable" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Ellipse Width="12" Height="12" Fill="Green" VerticalAlignment="Center"/>
                                    <TextBlock Text="Available" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>

                            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="Total price"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center">
                                    <Run Text="{Binding TotalPrice}"/>
                                    <Run Text=" $"/>
                                </TextBlock>
                            </Grid>

                            <Button Content="Book now"
                                    Click="OnBookClicked"
                                    HorizontalAlignment="Stretch"
                                    FontSize="16"
                                    Padding="0,12"/>

                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

        </Grid>
    </Grid>
</Page>