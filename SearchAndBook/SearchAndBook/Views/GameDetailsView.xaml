<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SearchAndBook.Views.GameDetailsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SearchAndBook.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="25,75,25,25">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDE -->
        <StackPanel Grid.Column="0" Spacing="20">

            <!-- TITLE -->
            <TextBlock Text="{Binding gameAndUserDetails.name}"
                       FontSize="28"
                       FontWeight="Bold"/>

            <!-- IMAGE + INFO SIDE BY SIDE -->
            <Grid ColumnDefinitions="2*,3*" ColumnSpacing="20">

                <!-- Image -->
                <Border Background="#DDD"
                        Height="200"
                        CornerRadius="10">
                    <TextBlock Text="{Binding gameAndUserDetails.image}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Info -->
                <StackPanel Grid.Column="1" Spacing="8" VerticalAlignment="Center">

                    <TextBlock>
                        <Run Text="📍 "/>
                        <Run Text="{Binding gameAndUserDetails.city}"/>
                    </TextBlock>

                    <TextBlock>
                        <Run Text="👥 "/>
                        <Run Text="{Binding gameAndUserDetails.minimumNrPlayers}"/>
                        <Run Text=" - "/>
                        <Run Text="{Binding gameAndUserDetails.maximumNrPlayers}"/>
                        <Run Text=" players"/>
                    </TextBlock>

                    <TextBlock>
                        <Run Text="💰 "/>
                        <Run Text="{Binding gameAndUserDetails.price}"/>
                        <Run Text="$/day"/>
                    </TextBlock>

                </StackPanel>

            </Grid>

            <!-- DESCRIPTION -->
            <StackPanel Spacing="5">
                <TextBlock Text="Description"
                           FontSize="20"
                           FontWeight="Bold"/>
                <TextBlock Text="{Binding gameAndUserDetails.description}"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <!-- OWNER + OTHER DETAILS SIDE BY SIDE -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="20">

                <!-- User's Profile -->
                <StackPanel Grid.Column="0" Spacing="8" HorizontalAlignment="Left">
                    <TextBlock Text="User's profile"
                               FontSize="16"
                               FontWeight="Bold"/>

                    <Ellipse Width="70" Height="70" Fill="#AAA"/>

                    <TextBlock Text="{Binding gameAndUserDetails.displayName}"
                               FontWeight="SemiBold"/>

                    <TextBlock FontSize="12">
                        <Run Text="Since "/>
                        <Run Text="{Binding gameAndUserDetails.createdAt}"/>
                    </TextBlock>

                    <Button Content="Chat with user"/>
                </StackPanel>

                <!-- Other Details -->
                <StackPanel Grid.Column="1" Spacing="8" VerticalAlignment="Top">
                    <TextBlock Text="Other details:"
                               FontSize="16"
                               FontWeight="Bold"/>
                    <TextBlock Text="• No dice"
                               TextWrapping="Wrap"/>
                </StackPanel>

            </Grid>

        </StackPanel>

        <!-- RIGHT SIDE -->
        <StackPanel Grid.Column="1" Spacing="20" VerticalAlignment="Top">

            <TextBlock Text="Choose date"
                       FontSize="20"
                       FontWeight="Bold"/>

            <CalendarView/>

            <TextBlock FontSize="16">
                <Run Text="Price: "/>
                <Run Text="{Binding gameAndUserDetails.price}"/>
                <Run Text="$"/>
            </TextBlock>

            <Button Content="Book"
                    Width="120"
                    Padding="10,5"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"/>

        </StackPanel>

    </Grid>
</Page>