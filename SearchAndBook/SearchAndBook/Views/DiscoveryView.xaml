<Page
    x:Class="SearchAndBook.Views.DiscoveryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:shared="using:SearchAndBook.Shared">

    <Grid Padding="20" RowSpacing="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- SEARCH BAR -->
        <Border Grid.Row="0"
                Padding="16"
                CornerRadius="8"
                BorderBrush="LightGray"
                BorderThickness="1">

            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="6">
                    <TextBlock Text="Game name"/>
                    <TextBox x:Name="GameTextBox"
                             PlaceholderText="Enter game name"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="6">
                    <TextBlock Text="City"/>
                    <AutoSuggestBox PlaceholderText="Enter city"
                                    Text="{x:Bind ViewModel.CitySearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    ItemsSource="{x:Bind ViewModel.CitySuggestions, Mode=OneWay}" />
                </StackPanel>

                <StackPanel Grid.Column="2" Spacing="6">
                    <TextBlock Text="Start date"/>
                    <CalendarDatePicker x:Name="StartDatePicker"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Spacing="6">
                    <TextBlock Text="End date"/>
                    <CalendarDatePicker x:Name="EndDatePicker"/>
                </StackPanel>

                <Button Grid.Column="4"
                        Content="Search"
                        Height="40"
                        VerticalAlignment="Bottom"
                        Click="Search_Click"/>
            </Grid>
        </Border>


        <!-- TITLE -->
        <TextBlock Grid.Row="1"
                   Text="Recommended Games"
                   FontSize="22"
                   FontWeight="SemiBold"/>

        <!-- RESULTS LIST -->
        <ListView Grid.Row="1"
                  Margin="0,40,0,0"
                  x:Name="GamesList"
                  SelectionMode="Single">

            
            <ListView.ItemTemplate>

                <!-- EXACT SAME CARD TEMPLATE -->
                <DataTemplate x:DataType="shared:GameDTO">

                    <Button Click="Game_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0">


                        <Border BorderBrush="LightGray"
                            BorderThickness="1"
                            CornerRadius="8"
                            Margin="0,0,0,10"
                            Height="180">

                            <Grid ColumnDefinitions="220,*"
                                ColumnSpacing="20"
                                Padding="20">

                                <!-- LEFT SIDE (IMAGE SPACE) -->
                                <Border Grid.Column="0"
                                    Background="LightGray"
                                    CornerRadius="8"/>

                                <!-- RIGHT SIDE (TEXT) -->
                                <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Spacing="8">

                                    <TextBlock Text="{x:Bind Name}"
                                        FontSize="20"
                                        FontWeight="Bold"/>

                                    <TextBlock Foreground="Gray">
                                        <Run Text="Price: " FontWeight="SemiBold"/>
                                        <Run Text="{x:Bind Price}"/>
                                    </TextBlock>

                                    <TextBlock Foreground="Gray">
                                        <Run Text="City: " FontWeight="SemiBold"/>
                                        <Run Text="{x:Bind City}"/>
                                    </TextBlock>

                                    <TextBlock Foreground="Gray">
                                        <Run Text="Players: " FontWeight="SemiBold"/>
                                        <Run Text="{x:Bind MinimumPlayerNumber}"/>
                                        <Run Text=" - "/>
                                        <Run Text="{x:Bind MaximumPlayerNumber}"/>
                                    </TextBlock>

                                </StackPanel>

                            </Grid>

                        </Border>

                    </Button>

                </DataTemplate>

            </ListView.ItemTemplate>

        </ListView>


        <!-- PAGINATION (copied exactly) -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="10">

            <Button Content="Previous"
                    Click="Previous_Click"/>

            <TextBlock x:Name="PageText"
                       VerticalAlignment="Center"/>

            <Button Content="Next"
                    Click="Next_Click"/>

        </StackPanel>

    </Grid>
</Page>