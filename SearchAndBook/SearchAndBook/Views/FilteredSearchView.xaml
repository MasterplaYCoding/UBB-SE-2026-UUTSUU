<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SearchAndBook.Views.FilteredSearchView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="20" RowSpacing="20" ColumnSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP SEARCH AREA -->
        <Border Grid.Row="0"
                Padding="16"
                CornerRadius="8"
                BorderBrush="LightGray"
                BorderThickness="1">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="6">
                    <TextBlock Text="Game name"/>
                    <TextBox Text="{Binding Filter.Name, Mode=TwoWay}"
                             PlaceholderText="Enter game name"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="6">
                    <TextBlock Text="City"/>
                    <TextBox Text="{Binding Filter.City, Mode=TwoWay}"
                             PlaceholderText="Enter city"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Spacing="6">
                    <TextBlock Text="Start date"/>
                    <CalendarDatePicker Date="{Binding Filter.StartDate, Mode=TwoWay}"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Spacing="6">
                    <TextBlock Text="End date"/>
                    <CalendarDatePicker Date="{Binding Filter.EndDate, Mode=TwoWay}"/>
                </StackPanel>

                <Button Grid.Column="4"
                        Content="Search"
                        Height="40"
                        VerticalAlignment="Bottom"
                        Command="{Binding SearchCommand}"/>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1" ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT FILTER PANEL -->
            <Border Grid.Column="0"
                    Padding="16"
                    CornerRadius="8"
                    BorderBrush="LightGray"
                    BorderThickness="1">
                <StackPanel Spacing="16">

                    <TextBlock Text="Filters"
                               FontSize="22"
                               FontWeight="SemiBold"/>

                    <!-- Sort -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="Sort by price"/>

                        <RadioButtons SelectedItem="{Binding SelectedSortOption, Mode=TwoWay}">
                            <x:String>Ascending</x:String>
                            <x:String>Descending</x:String>
                        </RadioButtons>
                    </StackPanel>

                    <!-- Players -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="Minimum players"/>
                        <TextBox Text="{Binding Filter.MinimumPlayers, Mode=TwoWay}"
                                 PlaceholderText="e.g. 2"/>
                    </StackPanel>

                    <!-- Location -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="Location"/>
                        <TextBox Text="{Binding Filter.Location, Mode=TwoWay}"
                                 PlaceholderText="Filter by location"/>
                    </StackPanel>

                    <Button Content="Apply filters"
                            Command="{Binding SearchCommand}" />

                    <Button Content="Clear filters"
                            Command="{Binding ClearFiltersCommand}" />
                </StackPanel>
            </Border>

            <!-- RIGHT RESULTS PANEL -->
            <Grid Grid.Column="1" RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Results"
                           FontSize="22"
                           FontWeight="SemiBold"/>

                <ListView Grid.Row="1"
                          ItemsSource="{Binding GamesShown}"
                          SelectionMode="Single"
                          SelectedItem="{Binding SelectedGame, Mode=TwoWay}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="LightGray"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12"
                                    Margin="0,0,0,10">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="18"
                                               FontWeight="SemiBold"/>

                                    <TextBlock>
                                        <Run Text="Genre: "/>
                                        <Run Text="{Binding Genre}"/>
                                    </TextBlock>

                                    <TextBlock>
                                        <Run Text="Price: "/>
                                        <Run Text="{Binding Price}"/>
                                    </TextBlock>

                                    <TextBlock>
                                        <Run Text="City: "/>
                                        <Run Text="{Binding City}"/>
                                    </TextBlock>

                                    <TextBlock>
                                        <Run Text="Players: "/>
                                        <Run Text="{Binding MinimumPlayers}"/>
                                        <Run Text=" - "/>
                                        <Run Text="{Binding MaximumPlayers}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Spacing="10">
                    <Button Content="Previous"
                            Command="{Binding PreviousPageCommand}"/>

                    <TextBlock Text="{Binding CurrentPage}"
                               VerticalAlignment="Center"/>

                    <Button Content="Next"
                            Command="{Binding NextPageCommand}"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>