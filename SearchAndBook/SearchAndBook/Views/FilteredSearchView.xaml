<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SearchAndBook.Views.FilteredSearchView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="Root"
    xmlns:viewModels="using:SearchAndBook.ViewModels"
    xmlns:shared="using:SearchAndBook.Shared"
    mc:Ignorable="d">

    <Grid Padding="20" RowSpacing="20" ColumnSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP SEARCH AREA -->
        <Border Grid.Row="0"
                Padding="16"
                CornerRadius="8"
                BorderBrush="LightGray"
                BorderThickness="1">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="6">
                    <TextBlock Text="Game name"/>
                    <TextBox Text="{Binding CurrentFilter.Name, Mode=TwoWay}"
                             PlaceholderText="Enter game name"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="6">
                    <TextBlock Text="City"/>
                    <TextBox Text="{Binding CurrentFilter.City, Mode=TwoWay}"
                             PlaceholderText="Enter city"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Spacing="6">
                    <TextBlock Text="Start date"/>
                    <CalendarDatePicker Date="{Binding SelectedStartDate, Mode=TwoWay}"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Spacing="6">
                    <TextBlock Text="End date"/>
                    <CalendarDatePicker Date="{Binding SelectedEndDate, Mode=TwoWay}"/>
                </StackPanel>

                <Button Grid.Column="4"
                        Content="Search"
                        Height="40"
                        VerticalAlignment="Bottom"
                        Command="{Binding SearchCommand}"/>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1" ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT FILTER PANEL -->
            <Border Grid.Column="0"
                    Padding="16"
                    CornerRadius="8"
                    BorderBrush="LightGray"
                    BorderThickness="1">
                <StackPanel Spacing="16">

                    <TextBlock Text="Filters"
                               FontSize="22"
                               FontWeight="SemiBold"/>

                    <!-- Sort by Maximum Price -->
                    <TextBlock Text="Maximum Price"/>
                    <Slider
                        Minimum="1"
                        Maximum="100"
                        Value="{Binding SelectedMaximumPrice, Mode=TwoWay}"/>

                    <!-- Players -->
                    <TextBlock Text="Number of players"/>
                    <Slider
                        Minimum="1"
                        Maximum="20"
                        Value="{Binding SelectedMinimumPlayers, Mode=TwoWay}"/>

                    <!-- Sort by Price -->
                    <TextBlock
                        Text="Sort by"
                        FontWeight="Bold"
                        Margin="0,10,0,0"/>


                    <RadioButtons SelectedItem="{Binding SelectedSortOption, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">

                        <x:String>Price: lowest to highest</x:String>
                        <x:String>Price: highest to lowest</x:String>

                    </RadioButtons>

                    <!-- Location -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="Location"/>
                        <TextBox 
                                 PlaceholderText="Filter by location"/>
                    </StackPanel>

                    <Button Content="Apply filters"
                            Command="{Binding ApplySelectedUiFiltersCommand}" />

                    <Button Content="Clear filters"
                            Command="{Binding ClearFiltersCommand}" />
                </StackPanel>
            </Border>

            <!-- RIGHT RESULTS PANEL -->
            <Grid Grid.Column="1" RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Results"
                           FontSize="22"
                           FontWeight="SemiBold"/>

                <ListView Grid.Row="1"
                          ItemsSource="{Binding GamesShown, Mode=OneWay}"
                          SelectionMode="Single"
                          SelectedItem="{Binding SelectedGame, Mode=TwoWay}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="shared:GameDTO">
                            <Border BorderBrush="LightGray"
                                BorderThickness="1"
                                CornerRadius="8"
                                Margin="0,0,0,10"
                                Height="180">
                            <Grid ColumnDefinitions="220,*" ColumnSpacing="20">

                                <Border Grid.Column="0"
                                        CornerRadius="8,0,0,8">
                                    
                                    <Border.Background>
                                        <ImageBrush
                                            ImageSource="{x:Bind GameImage, Mode=OneWay}"
                                            Stretch="UniformToFill"/>
                                        </Border.Background>
                                    </Border>

                                    <StackPanel Grid.Column="1" 
                                                VerticalAlignment="Center" 
                                                Spacing="8">

                                        <TextBlock Text="{x:Bind Name}"
                                                    FontSize="20"
                                                    FontWeight="Bold"/>

                                        <TextBlock Foreground="Gray">
                                            <Run Text="Price: " FontWeight="SemiBold"/>
                                            <Run Text="{x:Bind Price}"/>
                                        </TextBlock>

                                        <TextBlock Foreground="Gray">
                                            <Run Text="City: " FontWeight="SemiBold"/>
                                            <Run Text="{x:Bind City}"/>
                                        </TextBlock>

                                        <TextBlock Foreground="Gray">
                                            <Run Text="Players: " FontWeight="SemiBold"/>
                                            <Run Text="{x:Bind MinimumPlayerNumber}"/>
                                            <Run Text=" - "/>
                                            <Run Text="{x:Bind MaximumPlayerNumber}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Spacing="10">
                    <Button Content="Previous"
                            Command="{Binding PreviousPageCommand}"/>

                    <TextBlock Text="{Binding CurrentPage}"
                               VerticalAlignment="Center"/>

                    <Button Content="Next"
                            Command="{Binding NextPageCommand}"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>